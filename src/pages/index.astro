---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => {
		const dateA = a.data.date ? new Date(a.data.date).valueOf() : 0;
		const dateB = b.data.date ? new Date(b.data.date).valueOf() : 0;
		return dateB - dateA;
	}
);

const colors = ['bg-brutalist-yellow', 'bg-brutalist-pink', 'bg-brutalist-blue', 'bg-brutalist-green', 'bg-brutalist-orange'];
---

<Layout>
	<!-- Hero Section -->
	<section class="border-b-3 border-brutalist-black bg-brutalist-yellow">
		<div class="max-w-5xl mx-auto px-6 py-8 md:py-10">
			<h1 class="text-3xl md:text-5xl font-bold leading-tight mb-3 text-brutalist-black">
				THOUGHTS.<br/>
				CODE.<br/>
				<span class="inline-block bg-brutalist-black text-brutalist-white px-3 py-1">DESIGN.</span>
			</h1>
			<p class="text-base md:text-lg max-w-2xl text-brutalist-black">
				A neobrutalist blog where I write about web development, design philosophy, and the occasional random thought.
			</p>
		</div>
	</section>

	<!-- Blog Posts -->
	<section class="max-w-5xl mx-auto px-6 py-8">
		<h2 class="text-xl font-bold mb-6 flex items-center gap-3">
			<span class="inline-block w-5 h-1 bg-brutalist-black"></span>
			LATEST POSTS
		</h2>

		<div class="grid gap-4">
			{posts.map((post, index) => (
				<article class="brutal-card group py-3 px-4">
					<div class="flex flex-col md:flex-row gap-3">
						<div class={`w-full md:w-24 h-20 md:h-auto ${colors[index % colors.length]} brutal-border flex items-center justify-center shrink-0`}>
							<span class="text-2xl font-bold text-brutalist-black">{String(index + 1).padStart(2, '0')}</span>
						</div>
						<div class="flex-1">
							<h3 class="text-lg md:text-xl font-bold mb-1 group-hover:text-brutalist-pink transition-colors">
								<a href={`/${post.slug}`} class="hover:underline decoration-3 underline-offset-4">
									{post.data.title}
								</a>
							</h3>
							{post.data.description && (
								<p class="text-sm opacity-80 mb-2">
									{post.data.description}
								</p>
							)}
							{post.data.date && (
								<time class="font-mono text-xs">
									{new Date(post.data.date).toLocaleDateString('en-US', {
										year: 'numeric',
										month: 'short',
										day: 'numeric'
									})}
								</time>
							)}
						</div>
					</div>
				</article>
			))}
		</div>
	</section>
</Layout>
