---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => {
		const dateA = a.data.date ? new Date(a.data.date).valueOf() : 0;
		const dateB = b.data.date ? new Date(b.data.date).valueOf() : 0;
		return dateB - dateA;
	}
);

const colors = ['bg-gray-100', 'bg-gray-200', 'bg-gray-300', 'bg-gray-400', 'bg-gray-500'];
---

<Layout>
	<section class="border-b border-gray-200 dark:border-gray-800">
		<div class="max-w-5xl mx-auto px-6 py-10 md:py-12">
			<h1 class="text-2xl md:text-3xl lg:text-4xl font-bold leading-tight mb-3 text-gray-900 dark:text-gray-100">
				Thoughts.<br/>
				Code.<br/>
				<span class="inline-block bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 px-2 py-0.5">Design.</span>
			</h1>
			<p class="text-base md:text-lg max-w-2xl text-gray-600 dark:text-gray-400">
				A blog where I write about web development, design philosophy, and the occasional random thought.
			</p>
		</div>
	</section>

	<section class="max-w-5xl mx-auto px-6 py-8">
		<h2 class="text-lg font-semibold mb-6 text-gray-900 dark:text-gray-100">Latest Posts</h2>

		<div class="grid gap-4">
			{posts.map((post, index) => (
				<a href={`/${post.slug}`}>
					<article class="border border-gray-200 dark:border-gray-800 rounded-lg p-4 hover:shadow-sm transition-shadow">
						<div class="flex flex-col md:flex-row gap-4">
							<div class={`w-full md:w-20 h-16 flex items-center justify-center shrink-0 ${colors[index % colors.length]} dark:bg-gray-800 rounded`}>
								<span class="text-xl font-bold text-gray-700 dark:text-gray-300">{String(index + 1).padStart(2, '0')}</span>
							</div>
							<div class="flex-1">
								<h3 class="text-lg font-semibold mb-1 text-gray-900 dark:text-gray-100 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
									{post.data.title}
								</h3>
								{post.data.description && (
									<p class="text-sm text-gray-600 dark:text-gray-400 mb-2">
										{post.data.description}
									</p>
								)}
								{post.data.date && (
									<time class="font-mono text-xs text-gray-500 dark:text-gray-500">
										{new Date(post.data.date).toLocaleDateString('en-US', {
											year: 'numeric',
											month: 'short',
											day: 'numeric'
										})}
									</time>
								)}
							</div>
						</div>
					</article>
				</a>
			))}
		</div>
	</section>
</Layout>
