---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}

const post = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} | My Blog`} description={post.data.description}>
	<article>
		<header class="border-b border-gray-200 dark:border-gray-800">
			<div class="max-w-4xl mx-auto px-6 py-10">
				<h1 class="text-2xl md:text-3xl lg:text-4xl font-bold leading-tight mb-3 text-gray-900 dark:text-gray-100">
					{post.data.title}
				</h1>
				{post.data.description && (
					<p class="text-base md:text-lg mb-4 text-gray-600 dark:text-gray-400">
						{post.data.description}
					</p>
				)}
				{post.data.date && (
					<div class="flex items-center gap-4">
						<time class="font-mono text-sm text-gray-500 dark:text-gray-500">
							{new Date(post.data.date).toLocaleDateString('en-US', {
								year: 'numeric',
								month: 'short',
								day: 'numeric'
							})}
						</time>
					</div>
				)}
			</div>
		</header>

		<div class="max-w-4xl mx-auto px-6 py-10">
			<div class="prose dark:prose-invert max-w-none">
				<Content />
			</div>
		</div>

		<div class="max-w-4xl mx-auto px-6 pb-10">
			<a href="/" class="inline-block text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
				&larr; Back to all posts
			</a>
		</div>
	</article>
</Layout>
