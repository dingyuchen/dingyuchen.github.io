---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}

const post = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} | BRUTAL.BLOG`} description={post.data.description}>
	<article>
		<!-- Post Header -->
		<header class="border-b-3 border-brutalist-black bg-brutalist-pink">
			<div class="max-w-4xl mx-auto px-6 py-10">
				<h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4 text-brutalist-black">
					{post.data.title}
				</h1>
				{post.data.description && (
					<p class="text-lg md:text-xl mb-4 opacity-90 text-brutalist-black">
						{post.data.description}
					</p>
				)}
				{post.data.date && (
					<div class="flex items-center gap-4">
						<time class="font-mono text-sm bg-brutalist-white text-brutalist-black px-3 py-1 brutal-border">
							{new Date(post.data.date).toLocaleDateString('en-US', {
								year: 'numeric',
								month: 'short',
								day: 'numeric'
							})}
						</time>
					</div>
				)}
			</div>
		</header>

		<!-- Post Content -->
		<div class="max-w-4xl mx-auto px-6 py-10">
			<div class="prose">
				<Content />
			</div>
		</div>

		<!-- Back Link -->
		<div class="max-w-4xl mx-auto px-6 pb-10">
			<a href="/" class="brutal-btn inline-block">
				&larr; BACK TO ALL POSTS
			</a>
		</div>
	</article>
</Layout>
