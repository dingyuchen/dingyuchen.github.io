---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About | My Blog" description="About the author and this blog">
	<section class="border-b border-gray-200 dark:border-gray-800">
		<div class="max-w-4xl mx-auto px-6 py-10 md:py-12">
			<h1 class="text-3xl md:text-4xl font-bold mb-3 text-gray-900 dark:text-gray-100">About</h1>
			<p class="text-lg text-gray-600 dark:text-gray-400">The human behind the blog.</p>
		</div>
	</section>

	<section class="max-w-4xl mx-auto px-6 py-10">
		<div class="grid md:grid-cols-3 gap-8">
			<div class="md:col-span-2 prose dark:prose-invert">
				<h2>Hello, World.</h2>
				<p>
					I'm a developer and designer who writes about web development, 
					design philosophy, and the occasional hot take on tech culture.
				</p>
				<h2>The Stack</h2>
				<p>
					This blog is built with:
				</p>
				<ul>
					<li><strong>Astro</strong> — For blazing fast static sites</li>
					<li><strong>Tailwind CSS</strong> — For utility-first styling</li>
					<li><strong>Shiki</strong> — For beautiful syntax highlighting</li>
				</ul>
				<h2>Get in Touch</h2>
				<p>
					Want to chat? Find me on the usual platforms or send an email.
					I'm always happy to discuss code, design, or the meaning of life.
				</p>
			</div>
			<aside>
				<div class="border border-gray-200 dark:border-gray-800 rounded-lg p-4">
					<h3 class="text-lg font-semibold mb-4 text-gray-900 dark:text-gray-100">Quick Facts</h3>
					<ul class="space-y-3 text-sm text-gray-600 dark:text-gray-400">
						<li class="flex items-start gap-2">
							<span class="font-medium">Location:</span>
							<span>The Internet</span>
						</li>
						<li class="flex items-start gap-2">
							<span class="font-medium">Tools:</span>
							<span>VS Code, TypeScript, Coffee</span>
						</li>
						<li class="flex items-start gap-2">
							<span class="font-medium">Currently:</span>
							<span>Building cool stuff</span>
						</li>
					</ul>
				</div>
			</aside>
		</div>
	</section>
</Layout>
