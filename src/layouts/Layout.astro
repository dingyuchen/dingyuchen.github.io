---
import '../styles/global.css';
import 'katex/dist/katex.min.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "BRUTALIST BLOG",
	description = "A neobrutalist blog about design, code, and creativity"
} = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />

		<!-- Syntax Highlighting - Catppuccin -->
		<link rel="stylesheet" href="https://unpkg.com/@catppuccin/highlightjs@1.0.0/css/catppuccin-latte.css" id="hljs-light" />
		<link rel="stylesheet" href="https://unpkg.com/@catppuccin/highlightjs@1.0.0/css/catppuccin-macchiato.css" id="hljs-dark" disabled />

		<script is:inline>
			// Check for saved theme preference or default to light
			const getTheme = () => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
			};

			const setTheme = (theme) => {
				if (theme === 'dark') {
					document.documentElement.classList.add('dark');
					document.getElementById('hljs-light')?.setAttribute('disabled', '');
					document.getElementById('hljs-dark')?.removeAttribute('disabled');
				} else {
					document.documentElement.classList.remove('dark');
					document.getElementById('hljs-dark')?.setAttribute('disabled', '');
					document.getElementById('hljs-light')?.removeAttribute('disabled');
				}
				localStorage.setItem('theme', theme);
			};

			// Apply theme immediately to prevent flash
			setTheme(getTheme());

			// Make toggleTheme available globally
			window.toggleTheme = () => {
				const current = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
				setTheme(current === 'dark' ? 'light' : 'dark');
			};
		</script>

		<title>{title}</title>
	</head>
	<body class="min-h-screen flex flex-col">
		<header class="border-b-3 border-brutalist-black bg-brutalist-white">
			<nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
				<a href="/" class="text-2xl font-bold tracking-tight hover:text-brutalist-pink transition-colors">
					BRUTAL<span class="text-brutalist-yellow">.</span>BLOG
				</a>
				<div class="flex items-center gap-6">
					<a href="/" class="font-bold hover:text-brutalist-pink transition-colors">HOME</a>
					<a href="/about" class="font-bold hover:text-brutalist-pink transition-colors">ABOUT</a>
					<button
						onclick="toggleTheme()"
						class="theme-toggle"
						aria-label="Toggle dark mode"
					>
						<svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
						</svg>
						<svg class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
						</svg>
					</button>
				</div>
			</nav>
		</header>

		<main class="flex-1">
			<slot />
		</main>

		<footer class="border-t-3 border-brutalist-black bg-brutalist-black text-brutalist-white">
			<div class="max-w-5xl mx-auto px-6 py-8">
				<div class="flex flex-col md:flex-row justify-between items-center gap-4">
					<p class="font-bold">BRUTAL.BLOG &copy; {new Date().getFullYear()}</p>
					<div class="flex gap-4">
						<a href="#" class="hover:text-brutalist-yellow transition-colors">Twitter</a>
						<a href="#" class="hover:text-brutalist-yellow transition-colors">GitHub</a>
						<a href="#" class="hover:text-brutalist-yellow transition-colors">RSS</a>
					</div>
				</div>
			</div>
		</footer>
	</body>
</html>
